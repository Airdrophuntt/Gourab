rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Post Validation
    function isValidPost(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time &&
             (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    function isValidUpdate(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.updatedAt == request.time;
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via console for security
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow list: if resource.data.published == true || isAdmin();
      
      allow create: if isAdmin() && isValidId(postId) &&
                      request.resource.data.keys().hasAll(['title', 'content', 'authorId', 'createdAt', 'published']) &&
                      isValidPost(request.resource.data);
                      
      allow update: if isAdmin() && isValidId(postId) &&
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      isValidUpdate(request.resource.data);
                      
      allow delete: if isAdmin();
    }
  }
}
